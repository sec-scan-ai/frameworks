{
  "Shopware 5": {
    "default_excludes": [
      "var/cache",
      "web/cache"
    ]
  },
  "Shopware 6": {
    "default_excludes": [
      "var/cache",
      "public/theme",
      "public/bundles"
    ]
  },
  "OXID eShop 6.x": {
    "default_excludes": [
      "source/tmp"
    ]
  },
  "OXID eShop 7.x": {
    "default_excludes": [
      "source/tmp",
      "var/cache"
    ]
  },
  "WordPress/WooCommerce": {
    "default_excludes": [
      "wp-content/cache"
    ]
  },
  "Magento": {
    "default_excludes": [
      "generated/code",
      "generated/metadata",
      "var/cache",
      "var/page_cache",
      "var/view_preprocessed",
      "var/session",
      "var/tmp",
      "includes/src"
    ]
  },
  "JTL-Shop 5": {
    "default_excludes": [
      "templates_c",
      "admin/templates_c"
    ]
  },
  "PrestaShop": {
    "default_excludes": [
      "var/cache"
    ]
  },
  "Sylius": {
    "default_excludes": [
      "var/cache"
    ]
  },
  "Laravel": {
    "default_excludes": [
      "storage/framework/views",
      "storage/framework/cache",
      "bootstrap/cache"
    ]
  },
  "Symfony": {
    "default_excludes": [
      "var/cache"
    ]
  }
}
